PORT=8001
APP_ENV=development
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=resource_db
AUTH_SERVICE_URL=http://auth-service:4001
EVENT_SERVICE_URL=http://event-service:8081
KAFKA_BOOTSTRAP_SERVERS=your-namespace.servicebus.windows.net:9093
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME='$ConnectionString'
KAFKA_SASL_PASSWORD=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY
KAFKA_SSL_CAFILE=
KAFKA_SSL_CHECK_HOSTNAME=true
KAFKA_RESOURCE_ALLOCATION_TOPIC=resource-allocation
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
HTTP_TIMEOUT_SECONDS=6
LOG_LEVEL=INFO
